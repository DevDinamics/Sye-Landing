---
// Importa tus componentes 
// Ajusta las rutas según donde guardaste los componentes
import PoliticasCalidadComponent from '../components/PoliticasCalidad.jsx'; 
import Navbar from '../components/Navbar.jsx'; 
import Footer from '../components/Footer.jsx';

import BackToTop from '../components/BackToTop.jsx';

// ─── VARIABLES SEO DINÁMICAS ───
const title = "Política de Calidad | SYE - Calidad y Mejora Continua";
const description = "Conoce la Política de Calidad de SYE Software, enfocada en la excelencia, estandarización y satisfacción del cliente basada en la norma ISO 9001:2015.";
const siteUrl = "https://www.syesoftware.com/politica-de-calidad"; 
const ogImage = "https://www.syesoftware.com/sye tarjeta.png"; 
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/Simbolo_sye_.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- 🌐 1. IMPORTACIÓN DE FUENTES CORPORATIVAS HOMOLOGADAS (Producción Blindada) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Poppins:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

  <!-- 🚀 SEO TÉCNICO BÁSICO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Política de Calidad, ISO 9001, Mejora Continua, Excelencia, Satisfacción del Cliente, SYE Software" />
  <meta name="author" content="SYE Software" />
  <link rel="canonical" href={siteUrl} />
  <meta name="theme-color" content="#050505" />

  <!-- 🌐 OPEN GRAPH -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="SYE Software" />

  <!-- 🐦 TWITTER CARDS -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={siteUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- 📊 GOOGLE ANALYTICS 4 (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script>

  <!-- 🚀 2. ESTILOS GLOBALES HOMOLOGADOS PARA PRODUCCIÓN -->
  <style is:global>
    * { 
      box-sizing: border-box; 
      margin: 0; 
      padding: 0; 
    }
    
    html, body {
      background-color: #050505;
      color: white;
      width: 100%;
      overflow-x: hidden;
      scroll-behavior: smooth;
      /* Asignamos Poppins como base secundaria por defecto */
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    /* Forzamos Poppins en textos planos para pisar estilos en línea de React */
    span, p, a, li, input, textarea, select { 
      font-family: 'Poppins', sans-serif !important; 
    }

    /* Forzamos Montserrat en todos los títulos, destacados y botones */
    h1, h2, h3, h4, h5, h6,
    .partners-title,
    .card-title,
    .devspace-card-title,
    .doma-card-title,
    .datos-card-title,
    .qopa-card-title,
    .compromisos-content strong,
    button,
    button[type="submit"] {
      font-family: 'Montserrat', sans-serif !important;
    }
  </style>
</head>
<body>
  <Navbar client:load /> 

  <PoliticasCalidadComponent client:load />

  <Footer client:load />

  <BackToTop client:load />
</body>
</html>