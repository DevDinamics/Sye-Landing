---
// Salimos de "pages" con "../" y entramos a "Services" o "components"
import HeroDoma from '../Services/Herodoma.jsx'; 
import Navbar from '../components/Navbar.jsx'; 
import DomaFeatures from '../Services/DomaFeatures.jsx'; 
import CallToAction from '../components/CallToAction.jsx';
import Footer from '../components/Footer.jsx';

// ─── VARIABLES SEO DINÁMICAS ───
const title = "DOMA | SYE - Automatización y Optimización de Procesos Institucionales";
const description = "Descubre DOMA de SYE Software. La solución avanzada para la automatización inteligente, control operativo y eficiencia en la gestión de flujos institucionales.";
const siteUrl = "https://www.syesoftware.com/doma"; // Ajusta la ruta exacta según tus subcarpetas
const ogImage = "https://www.syesoftware.com/sye tarjeta.png"; // Imagen épica 1200x630px para las redes
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/Simbolo_sye_.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;700&display=swap" rel="stylesheet">

  <!-- 🚀 SEO TÉCNICO BÁSICO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="DOMA, Automatización de Procesos, Eficiencia Operativa, Transformación Digital, Gestión Pública, SYE Software" />
  <meta name="author" content="SYE Software" />
  <link rel="canonical" href={siteUrl} />
  <meta name="theme-color" content="#050505" />

  <!-- 🌐 OPEN GRAPH (Tarjetas para redes sociales y WhatsApp) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="SYE Software" />

  <!-- 🐦 TWITTER CARDS -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={siteUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- 📊 GOOGLE ANALYTICS 4 (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    // 👉 REEMPLAZA "G-XXXXXXXXXX" CON EL ID REAL DE TU PROPIEDAD DE GA4
    gtag('config', 'G-XXXXXXXXXX');
  </script>

  <style is:global>
    /* Reseteo global consistente con el Dark Mode de SYE */
    * { 
      box-sizing: border-box; 
    }
    html, body {
      margin: 0;
      padding: 0;
      background-color: #050505;
      width: 100%;
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: white;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }
  </style>
</head>
<body>
  {/* Navbar interactivo */}
  <Navbar client:load /> 

  {/* Sección con las partículas 3D optimizada para DOMA */}
  <HeroDoma client:load />

  <DomaFeatures client:load />
  
  <CallToAction client:load />

  {/* Footer */}
  <Footer client:load />
</body>
</html>