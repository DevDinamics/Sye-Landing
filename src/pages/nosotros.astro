---
// Importa tus componentes usando la ruta relativa correcta
import NosotrosComponent from '../components/Nosotros.jsx';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';

import BackToTop from '../components/BackToTop.jsx';

// ─── VARIABLES SEO DINÁMICAS ───
const title = "Nosotros | SYE Software - Pasión por la Innovación y Evolución Digital";
const description = "Conoce a SYE Software. Somos un equipo apasionado por la ingeniería de software, la arquitectura en la nube y la transformación tecnológica de alto impacto.";
const siteUrl = "https://www.syesoftware.com/nosotros"; 
const ogImage = "https://www.syesoftware.com/sye tarjeta.png"; 
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/Simbolo_sye_.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- 🌐 FUENTES REDIRECCIONADAS VÍA CDN JSDELIVR (Bypassea bloqueos de Google Fonts en producción) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/poppins@5.0.8/index.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/montserrat@5.0.19/index.css" />

  <!-- 🚀 SEO TÉCNICO BÁSICO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Quiénes Somos, Equipo SYE, Filosofía Institucional, Valores Corporativos, Trayectoria TI, SYE Software" />
  <meta name="author" content="SYE Software" />
  <link rel="canonical" href={siteUrl} />
  <meta name="theme-color" content="#050505" />

  <!-- 🌐 OPEN GRAPH -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="SYE Software" />

  <!-- 🐦 TWITTER CARDS -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={siteUrl} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- 📊 GOOGLE ANALYTICS 4 (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script>

  <!-- 🚀 2. ESTILOS GLOBALES HOMOLOGADOS PARA PRODUCCIÓN -->
  <style is:global>
    * { 
      box-sizing: border-box; 
      margin: 0; 
      padding: 0; 
    }
    
    html, body {
      background-color: #050505;
      color: white;
      width: 100%;
      overflow-x: hidden;
      scroll-behavior: smooth;
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif !important;
    }

    /* 🎯 FIX ABSOLUTO PARA COMPONENTES REACT EN PRODUCCIÓN */
    div, section, main, article, span, p, a, li, input, textarea, select { 
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif !important; 
    }

    /* Forzamos Montserrat en encabezados, negritas y botones */
    h1, h2, h3, h4, h5, h6, strong,
    .partners-title,
    .card-title,
    .devspace-card-title,
    .doma-card-title,
    .datos-card-title,
    .qopa-card-title,
    .compromisos-content strong,
    button,
    button[type="submit"] {
      font-family: 'Montserrat', sans-serif !important;
    }
  </style>
</head>
<body>
  <div data-navbar-theme="dark">
    <Navbar client:load /> 
    
    <NosotrosComponent client:load />
    
    <Footer client:load />

    <BackToTop client:load />
  </div>
</body>
</html>