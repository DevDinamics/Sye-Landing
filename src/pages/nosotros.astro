---
import NosotrosComponent from '../components/Nosotros.jsx';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nosotros | SYE Software</title>
  <style is:global>
    html, body {
      margin: 0;
      padding: 0;
      background-color: #050505;
      width: 100%;
      height: 100%;
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', Roboto, sans-serif;
      color: white;
      /* Evita el scroll horizontal */
      overflow-x: hidden;
      /* Scroll suave nativo */
      scroll-behavior: smooth;
    }
  </style>
</head>
<body>
  {/* Agregamos el prop data-navbar-theme para que el Navbar detecte el fondo oscuro */}
  <div data-navbar-theme="dark">
    <Navbar client:load /> 
    <NosotrosComponent client:load />
    <Footer client:load />
  </div>
</body>
</html>