---
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';
import AvisoPrivacidad from '../components/AvisoPrivacidad.jsx';

// ─── VARIABLES SEO DINÁMICAS PARA ESTA PÁGINA ───
const title = "Aviso de Privacidad | SYE Software";
const description = "Conoce cómo protegemos y manejamos tus datos personales en SYE Software, en cumplimiento con la Ley Federal de Protección de Datos Personales.";
const siteUrl = "https://www.syesoftware.com/aviso-de-privacidad"; 
const ogImage = ""; // Puedes usar la misma imagen maestra
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/Simbolo_sye_.png" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- 🚀 SEO TÉCNICO -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={siteUrl} />
        <meta name="theme-color" content="#050505" />

        <!-- 🌐 OPEN GRAPH -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:site_name" content="SYE Software" />

        <!-- 🐦 TWITTER CARDS -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <!-- 📊 GOOGLE ANALYTICS 4 (GA4) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-XXXXXXXXXX');
        </script>

        <style>
          /* Reseteo global ajustado al Dark Mode */
          * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', system-ui, sans-serif; }
          body { background-color: #050505; color: #ffffff; overflow-x: hidden; }
        </style>
    </head>
    <body>
        <!-- Usamos client:load para hidratar el Navbar -->
        <Navbar client:load />
        
        <!-- Tu nuevo componente premium. ¡IMPORTANTE EL client:load por las animaciones de Framer Motion! -->
        <AvisoPrivacidad client:load />
        
        <!-- El Footer para cerrar la página -->
        <Footer client:load />
    </body>
</html>