---
// Tu archivo index.astro actual con SEO dinámico
import Navbar from '../components/Navbar.jsx';
import Hero from '../components/Hero.jsx';
import ServicesGrid from '../components/ServicesGrid.jsx';
import Partners from '../components/Partners.jsx';
import Footer from '../components/Footer.jsx';
import CasoExito from '../components/CasoExito.jsx';
import Certifications from '../components/Certifications.jsx';
import CallToAction from '../components/CallToAction.jsx';

import BackToTop from '../components/BackToTop.jsx';

const title = "SYE Software | Soluciones Tecnológicas y Transformación Digital";
const description = "Diseñamos y operamos arquitecturas en la Nube, Fábrica de Software e Inteligencia Artificial.";
const siteUrl = "https://www.syesoftware.com"; 
const ogImage = `${siteUrl}/sye tarjeta.png`; 
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/Simbolo_sye_.png" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- 🌐 FUENTES REDIRECCIONADAS VÍA CDN JSDELIVR (Bypassea bloqueos de Google Fonts) -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/poppins@5.0.8/index.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/montserrat@5.0.19/index.css" />
        
        <!-- SEO y G4... (Lo demás se queda igual) -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content="Fábrica de Software, SYE Software" />
        <link rel="canonical" href={siteUrl} />
        <meta name="theme-color" content="#050505" />

        <!-- 📊 GOOGLE ANALYTICS 4 (GA4) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-XXXXXXXXXX');
        </script>

        <!-- 🚀 APLICACIÓN DE LAS FUENTES GLOBALES -->
        <style is:global>
          * { 
            box-sizing: border-box; 
            margin: 0; 
            padding: 0; 
          }
          
          html, body {
            background-color: #050505;
            color: white;
            width: 100%;
            overflow-x: hidden;
            scroll-behavior: smooth;
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif !important;
          }

          /* 🎯 FIX ABSOLUTO PARA COMPONENTES REACT EN PRODUCCIÓN */
          div, section, article, span, p, a, li, input, textarea, select { 
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif !important; 
          }

          /* Forzamos Montserrat en encabezados, negritas y botones */
          h1, h2, h3, h4, h5, h6, strong,
          .partners-title,
          .card-title,
          .devspace-card-title,
          .doma-card-title,
          .datos-card-title,
          .qopa-card-title,
          .compromisos-content strong,
          button,
          button[type="submit"] {
            font-family: 'Montserrat', sans-serif !important;
          }
        </style>
    </head>
    <body>
        <Navbar client:load />
        <Hero client:load />
        <ServicesGrid client:load />
        <Partners client:load />
        <CasoExito client:load />
        <Certifications client:load />
        <CallToAction client:load />
        <Footer client:load />
        <BackToTop client:load />
    </body>
</html>