---
import Navbar from '../components/Navbar.jsx'; 
import ContactForm from '../components/ContactForm.jsx';

---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contacto | SYE Software</title>
  <meta name="description" content="Ponte en contacto con SYE Software para modernizar tus procesos e infraestructura.">
  
  <style is:global>
    html, body {
      margin: 0;
      padding: 0;
      background-color: #050505;
      width: 100%;
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
      color: white;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }
    
    /* Agregamos un pequeño estilo global para el focus de los inputs del formulario */
    input:focus, textarea:focus {
      border-bottom-color: #ffffff !important;
    }
    
    /* Placeholder sutil */
    ::placeholder {
      color: rgba(255, 255, 255, 0.3);
    }
  </style>
</head>
<body>
  <div data-navbar-theme="dark">
    <Navbar client:load /> 
    
    <main>
      <ContactForm client:load />
    </main>


  </div>
</body>
</html>